// Package httptransport adapts HTTP requests to the service layer.
package httptransport

import (
	"net/http"

	"github.com/eyesofblue/jgo/middleware"
	"{{.Module}}/internal/service"
)

func NewHandler(application *service.Service, middlewares ...middleware.Middleware) http.Handler {
	mux := http.NewServeMux()
	registerGeneratedRoutes(mux, application, middlewares...)
	return mux
}
