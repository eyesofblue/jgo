// Package config loads generated service configuration from defaults, YAML,
// environment variables, and command-line flags.
package config

import (
	"bytes"
	"errors"
	"flag"
	"fmt"
	"io"
	"os"
	"strings"
	"time"

	"gopkg.in/yaml.v3"
)

const defaultPath = "configs/local.yaml"

// Duration is a YAML-friendly time.Duration.
type Duration struct {
	time.Duration
}

// UnmarshalText parses values such as 3s or 500ms.
func (duration *Duration) UnmarshalText(text []byte) error {
	value, err := time.ParseDuration(strings.TrimSpace(string(text)))
	if err != nil {
		return err
	}
	duration.Duration = value
	return nil
}

// Config is the generated service configuration.
type Config struct {
	Service   Service              `yaml:"service"`
	GRPC      GRPC                 `yaml:"grpc"`
	Management Management          `yaml:"management"`
	Telemetry Telemetry            `yaml:"telemetry"`
	RPCClient map[string]RPCClient `yaml:"rpc_client"`
}

type GRPC struct { Reflection Reflection `yaml:"reflection"`; TLS GRPCTLS `yaml:"tls"` }
type Reflection struct { Enabled bool `yaml:"enabled"` }
type GRPCTLS struct { Enabled bool `yaml:"enabled"`; CertFile string `yaml:"cert_file"`; KeyFile string `yaml:"key_file"`; ClientAuth string `yaml:"client_auth"`; ClientCAFile string `yaml:"client_ca_file"` }
type Management struct { Address string `yaml:"address"`; Metrics ManagementMetrics `yaml:"metrics"`; Readiness ManagementReadiness `yaml:"readiness"` }
type ManagementMetrics struct { Enabled bool `yaml:"enabled"`; Prometheus Prometheus `yaml:"prometheus"` }
type Prometheus struct { Enabled bool `yaml:"enabled"` }
type ManagementReadiness struct { Enabled bool `yaml:"enabled"`; Timeout Duration `yaml:"timeout"` }

// Service contains process-level server settings.
type Service struct {
	Name            string   `yaml:"name"`
	HTTPAddress     string   `yaml:"http_address"`
	GRPCAddress     string   `yaml:"grpc_address"`
	ShutdownTimeout Duration `yaml:"shutdown_timeout"`
}

// Telemetry contains process observability settings.
type Telemetry struct {
	Tracing Tracing `yaml:"tracing"`
	Metrics TelemetryMetrics `yaml:"metrics"`
}

type TelemetryMetrics struct { OTLP OTLPExporter `yaml:"otlp"` }

// Tracing configures W3C trace-context creation and optional OTLP export.
type Tracing struct {
	Enabled     bool         `yaml:"enabled"`
	SampleRatio float64      `yaml:"sample_ratio"`
	Exporter    OTLPExporter `yaml:"exporter"`
}

// OTLPExporter configures the OpenTelemetry OTLP/gRPC exporter.
type OTLPExporter struct {
	Enabled  bool   `yaml:"enabled"`
	Endpoint string `yaml:"endpoint"`
	Insecure bool   `yaml:"insecure"`
}

// RPCClient configures one named outbound gRPC dependency.
type RPCClient struct {
	Address string          `yaml:"address"`
	Timeout Duration        `yaml:"timeout"`
	TLS     RPCClientTLS    `yaml:"tls"`
	Readiness string        `yaml:"readiness"`
}

// RPCClientTLS configures transport security for an outbound gRPC dependency.
type RPCClientTLS struct {
	Enabled    bool   `yaml:"enabled"`
	ServerName string `yaml:"server_name"`
	CAFile     string `yaml:"ca_file"`
}

// Load applies flag > environment > YAML > default precedence.
func Load(arguments []string) (Config, error) {
	config := Config{
		Service: Service{
			Name:            "{{.Name}}",
			HTTPAddress:     ":8080",
			GRPCAddress:     ":9090",
			ShutdownTimeout: Duration{Duration: 10 * time.Second},
		},
		Telemetry: Telemetry{Tracing: Tracing{
			Enabled:     true,
			SampleRatio: 0.1,
			Exporter: OTLPExporter{
				Endpoint: "127.0.0.1:4317",
				Insecure: true,
			},
		}},
		GRPC: GRPC{TLS: GRPCTLS{ClientAuth: "none"}},
		Management: Management{Address: ":9091", Metrics: ManagementMetrics{Enabled: true, Prometheus: Prometheus{Enabled: true}}, Readiness: ManagementReadiness{Enabled: true, Timeout: Duration{Duration: time.Second}}},
	}

	set := flag.NewFlagSet("{{.Name}}", flag.ContinueOnError)
	set.SetOutput(io.Discard)
	path := set.String("config", envOr("JGO_CONFIG", defaultPath), "configuration YAML path")
	serviceName := set.String("service-name", "", "override service name")
	httpAddress := set.String("http-address", "", "override HTTP listen address")
	grpcAddress := set.String("grpc-address", "", "override gRPC listen address")
	managementAddress := set.String("management-address", "", "override management HTTP listen address")
	shutdownTimeout := set.String("shutdown-timeout", "", "override graceful shutdown timeout")
	if err := set.Parse(arguments); err != nil {
		return Config{}, fmt.Errorf("config: parse flags: %w", err)
	}
	if set.NArg() != 0 {
		return Config{}, fmt.Errorf("config: unexpected arguments: %s", strings.Join(set.Args(), " "))
	}

	contents, err := os.ReadFile(*path)
	if err != nil {
		return Config{}, fmt.Errorf("config: read %s: %w", *path, err)
	}
	decoder := yaml.NewDecoder(bytes.NewReader(contents))
	decoder.KnownFields(true)
	if err := decoder.Decode(&config); err != nil {
		return Config{}, fmt.Errorf("config: decode %s: %w", *path, err)
	}
	var extra any
	if err := decoder.Decode(&extra); err != io.EOF { if err == nil { err = errors.New("multiple YAML documents are not allowed") }; return Config{}, fmt.Errorf("config: decode %s: %w", *path, err) }

	if err := applyEnvironment(&config); err != nil {
		return Config{}, err
	}
	if *serviceName != "" {
		config.Service.Name = *serviceName
	}
	if *httpAddress != "" {
		config.Service.HTTPAddress = *httpAddress
	}
	if *grpcAddress != "" {
		config.Service.GRPCAddress = *grpcAddress
	}
	if *managementAddress != "" { config.Management.Address = *managementAddress }
	if *shutdownTimeout != "" {
		value, err := time.ParseDuration(*shutdownTimeout)
		if err != nil {
			return Config{}, fmt.Errorf("config: --shutdown-timeout: %w", err)
		}
		config.Service.ShutdownTimeout.Duration = value
	}
	if err := config.Validate(); err != nil {
		return Config{}, err
	}
	return config, nil
}

// Validate rejects configuration that cannot safely start a service.
func (config Config) Validate() error {
	if strings.TrimSpace(config.Service.Name) == "" {
		return errors.New("config: service.name is required")
	}
	if strings.TrimSpace(config.Service.HTTPAddress) == "" {
		return errors.New("config: service.http_address is required")
	}
	if strings.TrimSpace(config.Service.GRPCAddress) == "" {
		return errors.New("config: service.grpc_address is required")
	}
	if config.Service.ShutdownTimeout.Duration <= 0 {
		return errors.New("config: service.shutdown_timeout must be positive")
	}
	if config.Telemetry.Tracing.SampleRatio < 0 || config.Telemetry.Tracing.SampleRatio > 1 {
		return errors.New("config: telemetry.tracing.sample_ratio must be between 0 and 1")
	}
	if config.Telemetry.Tracing.Exporter.Enabled && strings.TrimSpace(config.Telemetry.Tracing.Exporter.Endpoint) == "" {
		return errors.New("config: telemetry.tracing.exporter.endpoint is required when export is enabled")
	}
	if strings.TrimSpace(config.Management.Address) == "" { return errors.New("config: management.address is required") }
	if config.Management.Readiness.Timeout.Duration <= 0 { return errors.New("config: management.readiness.timeout must be positive") }
	if config.GRPC.TLS.Enabled {
		if strings.TrimSpace(config.GRPC.TLS.CertFile) == "" || strings.TrimSpace(config.GRPC.TLS.KeyFile) == "" { return errors.New("config: grpc.tls.cert_file and key_file are required when TLS is enabled") }
		if config.GRPC.TLS.ClientAuth != "none" && config.GRPC.TLS.ClientAuth != "require_and_verify" { return errors.New("config: grpc.tls.client_auth must be none or require_and_verify") }
		if config.GRPC.TLS.ClientAuth == "require_and_verify" && strings.TrimSpace(config.GRPC.TLS.ClientCAFile) == "" { return errors.New("config: grpc.tls.client_ca_file is required for mTLS") }
	}
	if config.Telemetry.Metrics.OTLP.Enabled && strings.TrimSpace(config.Telemetry.Metrics.OTLP.Endpoint) == "" { return errors.New("config: telemetry.metrics.otlp.endpoint is required when export is enabled") }
	for name, client := range config.RPCClient {
		if strings.TrimSpace(name) == "" {
			return errors.New("config: rpc_client name is required")
		}
		if strings.TrimSpace(client.Address) == "" {
			return fmt.Errorf("config: rpc_client.%s.address is required", name)
		}
		if client.Timeout.Duration < 0 {
			return fmt.Errorf("config: rpc_client.%s.timeout must not be negative", name)
		}
		if client.Readiness != "" && client.Readiness != "optional" && client.Readiness != "required" { return fmt.Errorf("config: rpc_client.%s.readiness must be optional or required", name) }
	}
	return nil
}

func applyEnvironment(config *Config) error {
	if value := os.Getenv("JGO_SERVICE_NAME"); value != "" {
		config.Service.Name = value
	}
	if value := os.Getenv("JGO_HTTP_ADDRESS"); value != "" {
		config.Service.HTTPAddress = value
	}
	if value := os.Getenv("JGO_GRPC_ADDRESS"); value != "" {
		config.Service.GRPCAddress = value
	}
	if value := os.Getenv("JGO_MANAGEMENT_ADDRESS"); value != "" { config.Management.Address = value }
	if value := os.Getenv("JGO_SHUTDOWN_TIMEOUT"); value != "" {
		duration, err := time.ParseDuration(value)
		if err != nil {
			return fmt.Errorf("config: JGO_SHUTDOWN_TIMEOUT: %w", err)
		}
		config.Service.ShutdownTimeout.Duration = duration
	}
	return nil
}

func envOr(name, fallback string) string {
	if value := os.Getenv(name); value != "" {
		return value
	}
	return fallback
}
